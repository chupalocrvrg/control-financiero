rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // DEFAULT DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // GLOBAL HELPERS
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.role == 'SUPERADMIN' ||
        request.auth.token.role == 'ADMIN' ||
        request.auth.token.admin == true ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['SUPERADMIN', 'ADMIN']
        )
      );
    }

    function isSuperAdminFallback() {
      return isVerified() && (
        request.auth.token.role == 'SUPERADMIN' ||
        request.auth.token.admin == true
      );
    }

    function isEnterpriseData(data) {
      return isAccountActive() && (
        isAdmin() || 
        (
          'enterpriseId' in data && (
            data.enterpriseId == request.auth.uid || 
            (
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.enterpriseId == data.enterpriseId
            )
          )
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isVerified() && (request.auth.uid == userId);
    }

    function isOwnerOrAdmin(userId) {
      return isVerified() && (request.auth.uid == userId || isAdmin());
    }

    function isAccountActive() {
      return isAdmin() || (
        isVerified() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'ENABLED'
      );
    }

    // ===============================================================
    // VALIDATION BLUEPRINTS
    // ===============================================================

    function isValidUser(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string &&
             data.pin is string && (data.pin == "" || data.pin.matches('^\\d{6}$') || data.pin.matches('^[a-fA-F0-9]{64}$')) &&
             data.status in ['ENABLED', 'DISABLED'] &&
             data.role in ['SUPERADMIN', 'ADMIN', 'USER', 'BODEGUERO', 'enterprise', 'employee'] &&
             (!('ruc' in data) || data.ruc == null || (data.ruc is string && data.ruc.size() <= 50)) &&
             (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() <= 50)) &&
             data.createdAt is timestamp;
    }

    function isValidBeneficiary(data) {
      return (data.userId == request.auth.uid || isAdmin()) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.createdAt is timestamp;
    }

    function isValidInvoice(data) {
      return (data.userId == request.auth.uid || isAdmin()) &&
             data.beneficiaryName is string && data.beneficiaryName.size() > 0 &&
             data.concept is string && data.concept.size() > 0 &&
             data.totalValue is number && data.totalValue >= 0 &&
             data.finalTotal is number && data.finalTotal >= 0 &&
             data.months is number && data.months > 0 &&
             data.createdAt is timestamp;
    }

    function isValidCheck(data) {
      return (data.userId == request.auth.uid || isAdmin()) &&
             data.invoiceId is string &&
             data.amount is number && data.amount > 0 &&
             data.status in ['PENDING', 'PAID', 'DELETED'] &&
             data.createdAt is timestamp;
    }

    function isValidAudit(data) {
      return data.action is string && data.action.size() > 0 &&
             data.details is string && data.details.size() > 0 &&
             data.userId == request.auth.uid &&
             data.userEmail == request.auth.token.email &&
             (data.targetId == null || data.targetId is string) &&
             data.timestamp == request.time;
    }

    function isValidEmployee(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.lastName is string && data.lastName.size() > 0 && data.lastName.size() <= 100;
    }

    function isValidBudget(data) {
      return data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() <= 100 &&
             data.month is string && data.month.size() > 0 && data.month.size() <= 20 &&
             data.salesBudget is number && data.collectionsBudget is number;
    }

    function isValidSale(data) {
      return data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() <= 100 &&
             data.amount is number && 
             data.date is string && data.date.size() > 0 && data.date.size() <= 30;
    }

    function isValidCollection(data) {
      return data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() <= 100 &&
             data.amount is number && 
             data.date is string && data.date.size() > 0 && data.date.size() <= 30;
    }

    function isValidArticle(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.quantity is number;
    }

    function isValidWarehouse(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200;
    }

    function isValidWarehouseInventory(data) {
      return data.warehouseId is string && data.warehouseId.size() > 0 && data.warehouseId.size() <= 100 &&
             data.articleId is string && data.articleId.size() > 0 && data.articleId.size() <= 100 &&
             data.quantity is number;
    }

    function isValidTransfer(data) {
      return data.fromWarehouseId is string && data.fromWarehouseId.size() > 0 && data.fromWarehouseId.size() <= 100 &&
             data.toWarehouseId is string && data.toWarehouseId.size() > 0 && data.toWarehouseId.size() <= 100 &&
             data.articles is list && data.articles.size() <= 1000 &&
             data.reason is string && data.reason.size() <= 200;
    }

    function isValidLoanReturn(data) {
      return data.type in ['LOAN', 'RETURN'] &&
             data.articles is list && data.articles.size() <= 1000 &&
             data.personName is string && data.personName.size() > 0 && data.personName.size() <= 200;
    }

    function isValidInventorySale(data) {
      return data.clientName is string && data.clientName.size() > 0 && data.clientName.size() <= 200 &&
             data.sellerId is string && data.sellerId.size() > 0 && data.sellerId.size() <= 100 &&
             data.soldArticles is list && data.soldArticles.size() <= 1000;
    }

    // ===============================================================
    // COLLECTIONS
    // ===============================================================
    
    match /users/{userId} {
      allow get: if isOwnerOrAdmin(userId);
      allow list: if isAdmin();
      
      allow create: if isOwnerOrAdmin(userId) && isValidUser(incoming()) && 
                    (
                      isAdmin() || 
                      (incoming().role == 'USER' && incoming().status == 'ENABLED') ||
                      (incoming().role == 'SUPERADMIN' && incoming().status == 'ENABLED' && isSuperAdminFallback())
                    ) &&
                    incoming().createdAt == request.time;
      
      allow update: if isOwnerOrAdmin(userId) && (
        isAdmin() || (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'ruc', 'phone', 'pin', 'lastPinEntry', 'pinInactivityLimit']) &&
          isValidUser(incoming()) &&
          incoming().role == existing().role &&
          incoming().status == existing().status &&
          incoming().createdAt == existing().createdAt
        )
      );

      allow delete: if isAdmin();

      // Secure subcollection for private security hashes (e.g. pin hash, 2FA credentials)
      // Completely blocks all client-side reading (Zero-Trust) to prevent offline brute-force cracking
      match /private/security {
        allow read, list: if false;
        allow write: if false;
      }
    }

    match /beneficiaries/{id} {
      allow read, list: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isAccountActive() && isValidBeneficiary(incoming()) && isValidId(id) &&
                    incoming().createdAt == request.time;
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && isValidBeneficiary(incoming()) && incoming().enterpriseId == existing().enterpriseId;
      allow delete: if isVerified() && isEnterpriseData(resource.data);
    }

    match /invoices/{id} {
      allow read, list: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isAccountActive() && isValidInvoice(incoming()) && isValidId(id) &&
                    incoming().createdAt == request.time;
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && isValidInvoice(incoming()) && incoming().enterpriseId == existing().enterpriseId;
      allow delete: if isVerified() && isEnterpriseData(resource.data);
    }

    match /employees/{id} {
      allow read, delete: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isVerified() && isEnterpriseData(incoming()) && isValidEmployee(incoming());
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && incoming().enterpriseId == existing().enterpriseId && isValidEmployee(incoming());
    }
    match /budgets/{id} {
      allow read, delete: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isVerified() && isEnterpriseData(incoming()) && isValidBudget(incoming());
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && incoming().enterpriseId == existing().enterpriseId && isValidBudget(incoming());
    }
    match /sales/{id} {
      allow read, delete: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isVerified() && isEnterpriseData(incoming()) && isValidSale(incoming());
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && incoming().enterpriseId == existing().enterpriseId && isValidSale(incoming());
    }
    match /collections/{id} {
      allow read, delete: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isVerified() && isEnterpriseData(incoming()) && isValidCollection(incoming());
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && incoming().enterpriseId == existing().enterpriseId && isValidCollection(incoming());
    }
    match /articles/{id} {
      allow read, delete: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isVerified() && isEnterpriseData(incoming()) && isValidArticle(incoming());
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && incoming().userId == existing().userId && isValidArticle(incoming());
    }
    match /warehouses/{id} {
      allow read, delete: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isVerified() && isEnterpriseData(incoming()) && isValidWarehouse(incoming());
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && incoming().userId == existing().userId && isValidWarehouse(incoming());
    }
    match /warehouse_inventory/{id} {
      allow read, delete: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isVerified() && isEnterpriseData(incoming()) && isValidWarehouseInventory(incoming());
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && incoming().userId == existing().userId && isValidWarehouseInventory(incoming());
    }
    match /transfers/{id} {
      allow read, delete: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isVerified() && isEnterpriseData(incoming()) && isValidTransfer(incoming());
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && incoming().userId == existing().userId && isValidTransfer(incoming());
    }
    match /loans_returns/{id} {
      allow read, delete: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isVerified() && isEnterpriseData(incoming()) && isValidLoanReturn(incoming());
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && incoming().userId == existing().userId && isValidLoanReturn(incoming());
    }
    match /inventory_sales/{id} {
      allow read, delete: if isVerified() && isEnterpriseData(resource.data);
      allow create: if isVerified() && isEnterpriseData(incoming()) && isValidInventorySale(incoming());
      allow update: if isVerified() && isEnterpriseData(resource.data) && isEnterpriseData(incoming()) && incoming().userId == existing().userId && isValidInventorySale(incoming());
    }

    match /checks/{id} {
      allow read, list: if isVerified() && isEnterpriseData(resource.data);
      
      allow create: if isAccountActive() && isValidCheck(incoming()) && isValidId(id) && 
                    exists(/databases/$(database)/documents/invoices/$(incoming().invoiceId)) &&
                    incoming().createdAt == request.time;
      
      allow update: if isVerified() && (
        isAdmin() || (
          isEnterpriseData(resource.data) &&
          isValidCheck(incoming()) &&
          incoming().userId == existing().userId &&
          incoming().invoiceId == existing().invoiceId &&
          incoming().createdAt == existing().createdAt &&
          (
            // Action: Mark as Paid
            (existing().status == 'PENDING' && incoming().status == 'PAID' && 
             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paidAt', 'paidBy', 'amount'])) ||
            // Action: Soft Delete (from PENDING or PAID)
            ((existing().status == 'PENDING' || existing().status == 'PAID') && incoming().status == 'DELETED' &&
             incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
            // Action: Restore
            (existing().status == 'DELETED' && incoming().status == 'PENDING' &&
             incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
            // Allow general updates if still PENDING?
            (existing().status == 'PENDING' && incoming().status == 'PENDING')
          )
        )
      );
      
      allow delete: if isAdmin();
    }

    match /settings/{userId} {
      allow read: if isVerified() && (
        isOwnerOrAdmin(userId) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.enterpriseId == userId)
      );
      allow write: if isOwnerOrAdmin(userId);
    }
    match /userSettings/{userId} {
      allow read, write: if isOwnerOrAdmin(userId);
    }

    match /versions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /auditLogs/{id} {
      allow create: if isVerified() && isValidAudit(incoming()) && isValidId(id);
      allow get, list: if isAdmin();
    }

    match /system_errors/{id} {
      allow create: if isSignedIn() &&
                    incoming().keys().hasOnly(['userId','userEmail','error','module','componentStack','createdAt']) &&
                    incoming().createdAt == request.time &&
                    incoming().error is string && incoming().error.size() < 2000;
      allow read, update, delete: if isAdmin();
    }
  }
}
